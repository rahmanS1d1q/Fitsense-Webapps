# =============================================================================
# FitSense Platform — .env.example
# Salin file ini menjadi .env di VPS dan isi seluruh nilai yang diperlukan.
# JANGAN commit file .env yang sudah diisi ke Git.
# =============================================================================

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Gunakan nama service Docker sebagai host (bukan localhost)
DATABASE_URL=postgresql://fitsense:YOUR_DB_PASSWORD@postgres:5432/fitsense
POSTGRES_PASSWORD=YOUR_DB_PASSWORD

# ─── InfluxDB ─────────────────────────────────────────────────────────────────
INFLUX_URL=http://influxdb:8086
INFLUX_TOKEN=your-influx-admin-token
INFLUX_ORG=fitsense
INFLUX_BUCKET=heartrate
INFLUX_BUCKET_AGGREGATED=heartrate_aggregated
INFLUX_INIT_PASSWORD=your-influxdb-admin-ui-password

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── JWT & Auth ───────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-chars-change-in-prod
JWT_EXPIRES_IN=7d
MQTT_TOKEN_EXPIRES_IN=30m

# ─── MQTT Broker (EMQX) ───────────────────────────────────────────────────────
# Internal: API & ML service konek via Docker service name
MQTT_BROKER_INTERNAL=mqtt://emqx:1883
MQTT_BROKER_HOST=emqx
MQTT_BROKER_PORT=1883
ML_MQTT_USERNAME=ml_service
ML_MQTT_PASSWORD=your-ml-mqtt-password

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your-smtp-password
SMTP_FROM=FitSense <noreply@yourdomain.com>

# ─── API Server ───────────────────────────────────────────────────────────────
API_PORT=3001

# ML Feature Flag
# Set ML_ENABLED=true hanya jika service ML sudah berjalan dan model ML sudah siap.
# Saat ML_ENABLED=false, API akan skip semua pemanggilan anomaly-check ke ML service
# namun tetap menerima MQTT heart rate, memproses zona HR, dan menyimpan ke InfluxDB.
ML_ENABLED=false

# ML Service URL — Uncomment baris ini HANYA jika ML_ENABLED=true dan service ml berjalan.
# Untuk menjalankan ML service: docker compose --profile ml up -d
# ML_SERVICE_URL=http://ml:8000

# Domain dipakai untuk generate link email (reset password, invite)
APP_DOMAIN=YOUR_VPS_IP_OR_DOMAIN


# ─── CORS ─────────────────────────────────────────────────────────────────────
# Isi dengan URL publik frontend Anda agar API mengizinkan request browser.
# Pisahkan dengan koma jika lebih dari satu origin.
# Fase HTTP/IP (testing): CORS_ORIGIN=http://YOUR_VPS_IP
# Fase HTTPS/domain:      CORS_ORIGIN=https://yourdomain.com
CORS_ORIGIN=http://YOUR_VPS_IP

# ─── Web Dashboard (NEXT_PUBLIC_*) ────────────────────────────────────────────
# PENTING: variabel ini di-bundle ke JavaScript browser saat `docker build`.
# Harus berupa URL yang dapat diakses dari BROWSER pengguna, bukan nama service Docker.
#
# Fase awal: testing via IP VPS (HTTP tanpa SSL)
NEXT_PUBLIC_API_URL=http://YOUR_VPS_IP/api
NEXT_PUBLIC_MQTT_URL=ws://YOUR_VPS_IP:8084/mqtt
#
# Contoh dengan domain (HTTP, sebelum SSL):
# NEXT_PUBLIC_API_URL=http://fitsense.hint-lab.id/api
# NEXT_PUBLIC_MQTT_URL=ws://fitsense.hint-lab.id:8084/mqtt
#
# Fase production: setelah domain & SSL tersedia (HTTPS/WSS)
# NEXT_PUBLIC_API_URL=https://fitsense.hint-lab.id/api
# NEXT_PUBLIC_MQTT_URL=wss://fitsense.hint-lab.id:8084/mqtt

# ─── Test Environment (hanya untuk CI/CD, tidak dipakai di production) ────────
TEST_DATABASE_URL=postgresql://fitsense_test:test_password@localhost:5433/fitsense_test
TEST_INFLUX_URL=http://localhost:8087
TEST_INFLUX_TOKEN=test-token
TEST_INFLUX_ORG=fitsense_test
TEST_INFLUX_BUCKET=heartrate_test
TEST_REDIS_URL=redis://localhost:6380
TEST_API_PORT=3002
TEST_ML_PORT=8001

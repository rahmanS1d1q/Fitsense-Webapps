# ─────────────────────────────────────────────
.cache/
.parcel-cache/
.turbo/
*.pid
*.seed
*.pid.lock
.eslintcache
.stylelintcache
.sentryclirc
.vercel
.npm
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

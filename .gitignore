# ============================================
# FitSense Platform — .gitignore
# Target: GitHub push, Ubuntu 24.04 + Docker deployment
# ============================================

# ─────────────────────────────────────────────
# Environment & Secrets (JANGAN PERNAH PUSH)
# ─────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.development
.env.test
*.env.backup
.env.*.backup

# ─────────────────────────────────────────────
# Node.js (API Server & Web Dashboard)
# ─────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build outputs
dist/
build/
out/

# Next.js
.next/

# TypeScript cache
*.tsbuildinfo
.tscache/

# Test coverage
coverage/
.nyc_output/
*.lcov
.jest-cache/

# ─────────────────────────────────────────────
# Python (ML Service)
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
ENV/
env/
.python-version

# PyTest & Testing
.pytest_cache/
.hypothesis/
.mypy_cache/
.dmypy.json
dmypy.json
.ipynb_checkpoints

# Python packaging
*.egg-info/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg

# PyInstaller
*.manifest
*.spec

# Celery
celerybeat-schedule
celerybeat.pid


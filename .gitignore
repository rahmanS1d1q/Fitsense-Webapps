# ============================================
# FitSense Platform - .gitignore
# ============================================

# ─────────────────────────────────────────────
# Environment & Secrets
# ─────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.development
.env.test

# Backup env files
*.env.backup
.env.*.backup

# ─────────────────────────────────────────────
# Node.js (API Server & Web Dashboard)
# ─────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build outputs
dist/
build/
.next/
out/

# Dependency directories
jspm_packages/

# TypeScript cache
*.tsbuildinfo
.tscache/

# Test coverage
coverage/
.nyc_output/
*.lcov

# Jest
.jest-cache/

# ─────────────────────────────────────────────
# Python (ML Service)
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
ENV/
env/
.python-version

# PyTest
.pytest_cache/
.hypothesis/

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# Jupyter Notebook
.ipynb_checkpoints

# Python distribution / packaging
*.egg-info/
dist/
build/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg

# PyInstaller
*.manifest
*.spec

# Celery
celerybeat-schedule
celerybeat.pid

# ─────────────────────────────────────────────
# Docker & Container
# ─────────────────────────────────────────────
docker-compose.override.yml
.docker/

# Docker volumes (jika ada local mount)
volumes/
data/

# ─────────────────────────────────────────────
# Database & Storage
# ─────────────────────────────────────────────
# PostgreSQL
*.sql.backup
*.dump
postgres-data/

# InfluxDB
influxdb-data/
influxdb2-data/

# Redis
redis-data/
dump.rdb
appendonly.aof

# SQLite (jika ada testing local)
*.db
*.sqlite
*.sqlite3

# ─────────────────────────────────────────────
# EMQX
# ─────────────────────────────────────────────
emqx/data/
emqx/log/
emqx/plugins/

# ─────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# Application logs
app.log
error.log
access.log
combined.log

# PM2 logs
.pm2/

# ─────────────────────────────────────────────
# SSL Certificates
# ─────────────────────────────────────────────
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx
nginx/ssl/

# Let's Encrypt
certbot/

# ─────────────────────────────────────────────
# Uploads & Media
# ─────────────────────────────────────────────
uploads/
media/
assets/storage/
public/uploads/

# Temporary files
tmp/
temp/
*.tmp

# ─────────────────────────────────────────────
# IDE & Editor
# ─────────────────────────────────────────────
# VSCode
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
*.code-workspace

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~
.*.sw[a-p]

# Emacs
*~
\#*\#
.\#*

# ─────────────────────────────────────────────
# Operating System
# ─────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory
.Trash-*

# ─────────────────────────────────────────────
# Testing & CI/CD
# ─────────────────────────────────────────────
# Test artifacts
test-results/
test-reports/
screenshots/
videos/

# Playwright
playwright-report/
playwright/.cache/

# ─────────────────────────────────────────────
# Backup & Archive
# ─────────────────────────────────────────────
*.bak
*.backup
*.old
*.orig
*.swp
*.swo
*.tar.gz
*.zip
*.rar

# ─────────────────────────────────────────────
# Project Specific
# ─────────────────────────────────────────────
# Generated files
apps/api/migrations/*.backup.sql
apps/ml/models/trained/
scripts/*.backup.sh

# Local development files
local-config/
.local/

# Documentation builds
docs/_build/
site/

# Grafana data
grafana/data/

# ─────────────────────────────────────────────
# Security & Sensitive Data
# ─────────────────────────────────────────────
# SSH keys
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# API keys & tokens
.secrets/
secrets/
*.secret
*.token
.credentials

# Password files
passwords.txt
credentials.txt

# ─────────────────────────────────────────────
# Package Manager Locks (optional - comment out if you want to track them)
# ─────────────────────────────────────────────
# Uncomment below if you don't want to track lock files
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
# poetry.lock
# Pipfile.lock

# ─────────────────────────────────────────────
# Misc
# ─────────────────────────────────────────────
.cache/
.parcel-cache/
.turbo/
*.pid
*.seed
*.pid.lock

# ESLint cache
.eslintcache

# Stylelint cache
.stylelintcache

# Next.js cache
.next/
out/

# Sentry
.sentryclirc

# Vercel
.vercel

# TypeScript incremental build
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# ─────────────────────────────────────────────
# Keep Files (exceptions to ignore rules)
# ─────────────────────────────────────────────
!.env.example
!.vscode/settings.json.example
!.gitkeep

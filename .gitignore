ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory
.Trash-*

# ─────────────────────────────────────────────
# Root-level Markdown Reports (auto-generated, tidak perlu di-repo)
# CATATAN: README.md dan .env.example dikecualikan (lihat bagian Keep Files)
# ─────────────────────────────────────────────
API_DOCUMENTATION.md
API_ENDPOINTS.md
BACKEND_IMPLEMENTATION_STATUS.md
BUILD_SUCCESS_REPORT.md
CPANEL_DEPLOYMENT.md
DEPLOYMENT_GUIDE.md
LAYOUT_STANDARDIZATION_REPORT.md
MQTT_GUIDE_SUMMARY.md
MQTT_IMPLEMENTATION_GUIDE.md
TEST_REPORT_API.md
*.spec.md
*.README.md
fitsense.spec.md

# ─────────────────────────────────────────────
# Documentation folder (internal, tidak perlu di-repo)
# ─────────────────────────────────────────────
docs/

# ─────────────────────────────────────────────

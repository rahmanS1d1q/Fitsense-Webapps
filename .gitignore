# ─────────────────────────────────────────────
# Keep Files (exceptions — wajib di-track)
# ─────────────────────────────────────────────
!README.md
!.env.example
!.gitkeep
!apps/api/migrations/*.sql
!grafana/provisioning/**
!emqx/emqx.conf
!emqx/acl.conf
!nginx/nginx.conf
!scripts/db-clean.sh
!scripts/test-setup.sh